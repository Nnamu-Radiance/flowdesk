POSTGRES_USER=flowdesk
POSTGRES_PASSWORD=flowdesk
POSTGRES_DB=flowdesk_db
DATABASE_URL=postgresql://flowdesk:flowdesk@postgres:5432/flowdesk_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

JWT_SECRET_KEY=your-shared-jwt-secret-min-50-chars-keep-identical-across-services
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

AUTH_SERVICE_DEBUG=True
WORKFLOW_SERVICE_DEBUG=True
APPROVAL_SERVICE_DEBUG=True
NOTIFICATION_SERVICE_DEBUG=True
ANALYTICS_SERVICE_DEBUG=True

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM=noreply@flowdesk.local

USE_S3=False
MEDIA_ROOT=/app/media

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
